{
  "video": {
    "compression": {
      "probability": 0.2,
      "codec": "h264",
      "crf_range": [18, 35]
    },
    "blur": {
      "probability": 0.15,
      "types": ["gaussian", "motion"],
      "kernel_sizes": [3, 5]
    },
    "frame_drop": {
      "probability": 0.1,
      "max_frames": 3
    },
    "random_crop": {
      "probability": 0.3,
      "scale_range": [0.8, 1.0]
    },
    "color_jitter": {
      "probability": 0.25,
      "brightness": 0.15,
      "contrast": 0.15,
      "hue": 0.05,
      "saturation": 0.15
    }
  },
  "audio": {
    "gaussian_noise": {
      "probability": 0.3,
      "std_range": [0.005, 0.02]
    },
    "reverb": {
      "probability": 0.15,
      "impulse_responses": ["small_room", "conference_room", "car_cabin"]
    },
    "volume": {
      "probability": 0.2,
      "gain_range": [0.8, 1.2]
    },
    "time_stretch": {
      "probability": 0.15,
      "ratio_range": [0.95, 1.05]
    },
    "filter": {
      "probability": 0.2,
      "types": ["lowpass", "highpass", "bandpass"],
      "cutoff_hz": [800, 6000]
    }
  },
  "sync": {
    "desync": {
      "probability": 0.5,
      "frame_shift_range": [-6, 6]
    },
    "window_dropout": {
      "probability": 0.1,
      "max_frames": 2
    }
  }
}

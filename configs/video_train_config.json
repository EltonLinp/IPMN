{
  "data_dir": "processed/fakeav_large",
  "index_file": "processed/fakeav_large/preprocess_index.jsonl",
  "batch_size": 8,
  "lr": 3e-4,
  "num_workers": 8,
  "target_frames": 48,
  "epochs": 30,
  "patience": 8,
  "lr_patience": 4,
  "lr_factor": 0.5,
  "class_weights": false,
  "balanced_sampler": true,
  "augment": true,
  "horizontal_flip_prob": 0.5,
  "temporal_jitter": 4,
  "brightness_jitter": 0.1,
  "contrast_jitter": 0.1,
  "noise_std": 0.01,
  "grad_clip_norm": 1.5,
  "ema": true,
  "ema_decay": 0.998,
  "ema_start_epoch": 8
}
